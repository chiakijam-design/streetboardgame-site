# Cloudflare Pages 用HTTPヘッダー設定
# https://developers.cloudflare.com/pages/configuration/headers/

# すべてのアセットにセキュリティヘッダー
/*
  Content-Security-Policy: default-src 'none'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com; script-src-attr 'none'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob:; connect-src 'self' blob: https://www.google-analytics.com https://region1.google-analytics.com https://formspree.io; form-action 'self' https://formspree.io; frame-src 'none'; media-src 'none'; manifest-src 'self'; worker-src 'self'
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-Permitted-Cross-Domain-Policies: none
  Origin-Agent-Cluster: ?1
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), autoplay=(), browsing-topics=(), camera=(), display-capture=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), midi=(), payment=(), picture-in-picture=(), serial=(), usb=(), xr-spatial-tracking=()

/live
  Referrer-Policy: no-referrer
/live-ops
  Referrer-Policy: no-referrer
/remote
  Referrer-Policy: no-referrer
/api/*
  Referrer-Policy: no-referrer

# HTMLは短めキャッシュ (内容更新を素早く反映するため)
/*.html
  Cache-Control: no-cache, must-revalidate
/
  Cache-Control: no-cache, must-revalidate

# お題カードは容量が大きく更新頻度が低いため1日キャッシュ
/assets/cards/*
  Cache-Control: public, max-age=86400, must-revalidate

# キャラクター画像は同じファイル名で改善することがあるため1時間キャッシュ
/assets/character/*
  Cache-Control: public, max-age=3600, must-revalidate

# 結果・SNS画像は更新を素早く反映するため5分キャッシュ
/assets/results/*
  Cache-Control: public, max-age=300, must-revalidate

/assets/social/*
  Cache-Control: public, max-age=300, must-revalidate

# フォントはファイル名を変更したときだけ更新する
/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# ファイル名に内容ハッシュを含む本番JSは再訪時に再検証しない
/dist/*
  Cache-Control: public, max-age=31536000, immutable
/assets/vendor/*
  Cache-Control: public, max-age=31536000, immutable

# assets直下の更新可能な画像
/assets/apple-touch-icon.png
  Cache-Control: public, max-age=86400, must-revalidate
/assets/favicon-48.png
  Cache-Control: public, max-age=86400, must-revalidate
/assets/favicon-192.png
  Cache-Control: public, max-age=86400, must-revalidate
/assets/favicon-girl.png
  Cache-Control: public, max-age=86400, must-revalidate
/assets/ogp.jpg
  Cache-Control: public, max-age=300, must-revalidate
/assets/ogp-love.png
  Cache-Control: public, max-age=300, must-revalidate
/assets/ogp-friends.png
  Cache-Control: public, max-age=300, must-revalidate
/assets/ogp-family.png
  Cache-Control: public, max-age=300, must-revalidate
/assets/ogp-remote.png
  Cache-Control: public, max-age=300, must-revalidate
/assets/qr-site.png
  Cache-Control: public, max-age=300, must-revalidate

# 開発用の未ハッシュJSXだけ短めキャッシュ (本番はdistのハッシュ付きJSを使用)
/*.jsx
  Cache-Control: public, max-age=300, must-revalidate

# favicon
/favicon.ico
  Cache-Control: public, max-age=86400
/favicon.svg
  Cache-Control: public, max-age=86400

/manifest.webmanifest
  Content-Type: application/manifest+json; charset=utf-8
  Cache-Control: public, max-age=300, must-revalidate

/404.html
  X-Robots-Tag: noindex, follow
  Cache-Control: no-cache, must-revalidate

/sitemap.xml
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=60, must-revalidate

/robots.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=60, must-revalidate
