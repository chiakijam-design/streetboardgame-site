{
  "name": "streetboardgame-site",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node tools/build-js.mjs",
    "app:web": "pnpm run build && node tools/prepare-capacitor.mjs",
    "test": "pnpm run test:unit && pnpm run test:e2e",
    "test:unit": "node --test tests/unit/*.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "1.55.0",
    "esbuild": "0.25.6",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  }
}
